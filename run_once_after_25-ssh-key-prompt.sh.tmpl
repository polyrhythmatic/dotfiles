{{ "#!/bin/bash" }}
# SSH key prompt — surfaces the public key in a native dialog at the END
# of bootstrap, after all the noisy install scripts complete. Without this
# the public key emitted by run_once_before_06-setup-ssh.sh gets buried in
# thousands of lines of brew/defaults output and the user never sees it.
#
# Runs once per machine. Pairs with run_once_before_06-setup-ssh.sh, but
# split out so the dialog fires when the user is actually paying attention.

set -euo pipefail

KEY_PATH="$HOME/.ssh/id_ed25519.pub"

if [ ! -f "$KEY_PATH" ]; then
	echo "No SSH public key at $KEY_PATH — skipping prompt."
	echo "(Did run_once_before_06-setup-ssh.sh fail or get skipped?)"
	exit 0
fi

# Re-copy to clipboard in case earlier scripts overwrote it.
pbcopy < "$KEY_PATH"

PUB_KEY=$(cat "$KEY_PATH")

CHOICE=$(osascript <<APPLESCRIPT 2>/dev/null || echo "Done"
display dialog "Your SSH public key has been copied to the clipboard.

Add it to GitHub to enable git push over SSH:

$PUB_KEY" buttons {"Done", "Open GitHub"} default button "Open GitHub" with icon note with title "Dotfiles — SSH Key"
button returned of result
APPLESCRIPT
)

if [ "$CHOICE" = "Open GitHub" ]; then
	open "https://github.com/settings/keys"
	echo "Opened https://github.com/settings/keys — paste from clipboard to add the key."
else
	echo "SSH key is on your clipboard. Add it later at https://github.com/settings/keys"
fi
