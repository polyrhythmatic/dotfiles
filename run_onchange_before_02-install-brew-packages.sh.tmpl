{{ "#!/bin/bash" }}
# Install CLI tools via Brewfile.
# Re-runs when Brewfile_cli content changes.
# Brewfile_cli hash: {{ include "Brewfile_cli" | sha256sum }}

set -euo pipefail

{{ if eq .chezmoi.arch "arm64" -}}
eval "$(/opt/homebrew/bin/brew shellenv)"
{{ else -}}
eval "$(/usr/local/bin/brew shellenv)"
{{ end -}}

echo "Updating Homebrew..."
brew update

echo "Installing CLI packages from Brewfile_cli..."
brew bundle --no-lock --file="{{ .chezmoi.sourceDir }}/Brewfile_cli"

echo "Installing browsers for CLI tools..."
command -v agent-browser &>/dev/null && agent-browser install
command -v playwright-cli &>/dev/null && playwright-cli install

echo "Installing CLI skills..."
cd "$HOME"
command -v playwright-cli &>/dev/null && playwright-cli install --skills
npx -y skills add vercel-labs/agent-browser -y
npx -y skills add ChromeDevTools/chrome-devtools-mcp -y

echo "CLI packages installed."
