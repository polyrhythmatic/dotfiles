#!/bin/zsh

# Get current dir (so run this script from anywhere)

export DOTFILES_DIR
DOTFILES_DIR="$( cd "$( dirname "${(%):-%N}" )" && pwd )"

# Shell config wrapper files
# Instead of symlinking .zshrc/.zprofile (which get auto-appended to by
# external tools), we create wrapper files that source the repo versions.
# Re-running install.sh preserves any tool-appended content (idempotent).

echo "Setting up shell config wrapper files..."

for rcfile in .zshrc .zprofile; do
  DOTFILES_RC="$DOTFILES_DIR/runcom/$rcfile"
  RC_SOURCE="source \"$DOTFILES_RC\""
  TARGET="$HOME/$rcfile"

  if [ ! -f "$TARGET" ] || ! grep -qF "$DOTFILES_RC" "$TARGET"; then
    # Remove symlink if it exists
    [ -L "$TARGET" ] && rm "$TARGET"
    cat > "$TARGET" << EOF
# Managed by dotfiles — do not edit above the marker line
source "$DOTFILES_RC"
# --- LOCAL --- External tools may auto-append below this line ---
EOF
    echo "  Created wrapper: $TARGET"
  else
    echo "  Wrapper already exists: $TARGET"
  fi
done

# Create symlinks for configuration files that don't get auto-appended to
echo "Creating symlinks for configuration files..."
ln -sfv "$DOTFILES_DIR/.gitconfig" ~
ln -sfv "$DOTFILES_DIR/.gitignore" ~

# Claude Code configuration
echo "Setting up Claude Code configuration..."
mkdir -p ~/.claude/agents ~/.claude/skills
# Symlink portable standards into ~/.claude so skills can reference them
ln -sfv "$DOTFILES_DIR/claude/standards" ~/.claude/standards
# Symlink skill directories individually (preserves any non-dotfiles skills)
for skill_dir in "$DOTFILES_DIR/claude/skills"/*/; do
  skill_name=$(basename "$skill_dir")
  ln -sfv "$skill_dir" ~/.claude/skills/"$skill_name"
done
# Symlink agent files individually (preserves any non-dotfiles agents)
for agent_file in "$DOTFILES_DIR/claude/agents"/*.md; do
  ln -sfv "$agent_file" ~/.claude/agents/
done
# Symlink global MCP server configuration
ln -sfv "$DOTFILES_DIR/claude/mcp.json" ~/.claude/mcp.json

# Package managers & packages
echo "Installing packages and tools..."
. "$DOTFILES_DIR/install/brew.sh"

. "$DOTFILES_DIR/install/npm.sh"

if [ "$(uname)" = "Darwin" ]; then
  echo "Running macOS specific installations (mas, brew-cask)..."
  . "$DOTFILES_DIR/install/mas.sh"
  . "$DOTFILES_DIR/install/brew-cask.sh"
fi

# Run SSH setup script
echo "Setting up SSH configuration..."
. "$DOTFILES_DIR/install/ssh-setup.sh"

# Font check
. "$DOTFILES_DIR/install/fonts.sh"

# Terminal & prompt configuration
echo "Setting up terminal and prompt configuration..."

# Ghostty
mkdir -p ~/.config/ghostty/themes
ln -sfv "$DOTFILES_DIR/config/ghostty/config" ~/.config/ghostty/config
ln -sfv "$DOTFILES_DIR/config/ghostty/themes/Alabaster Dark" ~/.config/ghostty/themes/"Alabaster Dark"

# Starship
mkdir -p ~/.config
ln -sfv "$DOTFILES_DIR/config/starship.toml" ~/.config/starship.toml

# iTerm2 Dynamic Profile (only if iTerm2 is installed)
if [ -d "/Applications/iTerm.app" ]; then
  ITERM_PROFILES_DIR="$HOME/Library/Application Support/iTerm2/DynamicProfiles"
  mkdir -p "$ITERM_PROFILES_DIR"
  ln -sfv "$DOTFILES_DIR/config/iterm2/Default.json" "$ITERM_PROFILES_DIR/Dotfiles.json"
  echo "  iTerm2 Dynamic Profile installed."
else
  echo "  iTerm2 not found — skipping Dynamic Profile."
fi

# Claude Code settings
ln -sfv "$DOTFILES_DIR/claude/settings.json" ~/.claude/settings.json

# Apply macOS preferences
if [ "$(uname)" = "Darwin" ]; then
  echo "Applying macOS preferences..."
  . "$DOTFILES_DIR/install/macos.sh"
fi

echo "Dotfiles installation complete!"
